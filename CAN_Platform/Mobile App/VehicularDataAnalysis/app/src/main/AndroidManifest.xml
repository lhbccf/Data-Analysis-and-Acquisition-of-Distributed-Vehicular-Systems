<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Bluetooth feature permissions -->
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true"/>
    <uses-permission android:name="android.permission.BLUETOOTH"/>
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"/>
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"/>
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VehicularDataAnalysis"
        android:name=".VehicularApplication">
        <activity
            android:name=".screens.menu.MenuActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.VehicularDataAnalysis">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".screens.about.AboutActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.VehicularDataAnalysis" />
        <activity
            android:name=".screens.about.AboutDeviceActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.VehicularDataAnalysis" />
        <activity
            android:name=".screens.menu.DeviceMenuActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.VehicularDataAnalysis" />
        <activity
            android:name=".screens.display.DataDisplayActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.VehicularDataAnalysis" />
        <activity
            android:name=".screens.display.OverallStatsActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.VehicularDataAnalysis" />
        <activity
            android:name=".screens.menu.SessionMenuActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.VehicularDataAnalysis" />
        <activity
            android:name=".ui.BaseActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.VehicularDataAnalysis" />
    </application>

</manifest>